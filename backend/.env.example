# Conexao com o PostgreSQL que sobe no Docker (docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://helpdesk:helpdesk@localhost:5432/helpdesk_nassau

# Chave para assinar os tokens JWT. Troque por algo aleatorio em producao.
SECRET_KEY=troque-esta-chave-em-producao-helpdesk-nassau
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Origens liberadas para o frontend React (Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
